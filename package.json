{
  "name": "dropee",
  "version": "1.0.0",
  "description": "Drop it. Share it. — Fast, anonymous file sharing",
  "private": true,
  "workspaces": [
    "dropee-frontend",
    "dropee-backend"
  ],
  "scripts": {
    "frontend": "npm run dev --workspace=dropee-frontend",
    "backend": "npm run dev --workspace=dropee-backend",
    "dev": "concurrently \"npm run backend\" \"npm run frontend\""
  },
  "devDependencies": {
    "concurrently": "^8.0.0"
  }
}
